# --- База даних ---
# Railway надає DATABASE_URL автоматично при додаванні PostgreSQL.
# Локально (через docker-compose) використовуйте рядок нижче:
DATABASE_URL=postgresql://postgres:1234@localhost:5432/itblog

# Альтернатива DATABASE_URL — окремі змінні (якщо DATABASE_URL не заданий):
# PGHOST=localhost
# PGPORT=5432
# PGUSER=postgres
# PGPASSWORD=postgres
# PGDATABASE=itblog

# SSL для БД (на Railway/хмарі — true, локально — false/не задавати)
# PGSSL=false

# --- Сервер ---
PORT=4000

# Секрет для підпису JWT — ОБОВʼЯЗКОВО змініть у production!
JWT_SECRET=change-this-to-a-long-random-string

# Дозволений origin для CORS (URL вашого фронтенду). * — дозволити всі (лише для розробки)
CORS_ORIGIN=*

# Публічний URL бекенду (для формування посилань на завантажені зображення)
# PUBLIC_URL=https://your-backend.up.railway.app
