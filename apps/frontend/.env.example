# URL бекенду, ДОСТУПНИЙ З БРАУЗЕРА (для пошуку, адмінки, лічильника переглядів).
# Локально:
NEXT_PUBLIC_API_URL=http://localhost:4000
# На Railway — публічний домен бекенду, напр.:
# NEXT_PUBLIC_API_URL=https://it-blog-backend.up.railway.app

# URL бекенду для серверного рендерингу (Server Components).
# Якщо не заданий — використовується NEXT_PUBLIC_API_URL.
# На Railway можна вказати внутрішню адресу сервісу, напр.:
# API_URL=http://backend.railway.internal:4000
API_URL=http://localhost:4000

# Публічний URL самого сайту (для canonical, sitemap, Open Graph).
# Локально:
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# На Railway / вашому домені:
# NEXT_PUBLIC_SITE_URL=https://mynewsblog.pp.ua
